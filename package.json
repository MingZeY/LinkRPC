{
  "name": "linkrpc",
  "version": "1.0.21",
  "description": "TypeScript-based RPC framework with support for multiple connection types including HTTP, Socket, and SocketIO or custom",
  "author": "MingZeY <1552904342@qq.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/MingZeY/LinkRPC.git"
  },
  "keywords": [
    "rpc",
    "typescript"
  ],
  "license": "MIT",
  "files": [
    "dist/**/*"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "main": "dist/index.js",
  "type": "module",
  "types": "dist/index.d.ts",
  "scripts": {
    "test": "tsx test/test.ts",
    "playground": "tsx test/playground.ts",
    "build": "tsc -p tsconfig.build.json",
    "check": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/ws": "^8.18.1",
    "express": "^5.2.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tsx": "^4.21.0",
    "ws": "^8.20.0"
  }
}
