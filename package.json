{
  "name": "linkrpc",
  "version": "1.0.36",
  "description": "TypeScript-based RPC framework with support for multiple connection types including HTTP, Socket, and SocketIO or custom",
  "author": "MingZeY <1552904342@qq.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/MingZeY/LinkRPC.git"
  },
  "keywords": [
    "rpc",
    "typescript"
  ],
  "license": "MIT",
  "files": [
    "dist/**/*"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "browser": {
    "./dist/pipe.js": "./dist/pipe.browser.js"
  },
  "main": "dist/index.js",
  "type": "module",
  "types": "dist/index.d.ts",
  "scripts": {
    "test": "tsx test/test.ts",
    "playground": "tsx test/playground.ts",
    "build": "tsc -p tsconfig.src.json",
    "check:src": "tsc --noEmit -p tsconfig.src.json",
    "check:test": "npm run build && tsc --noEmit -p tsconfig.test.json",
    "check": "npm run check:test"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/ws": "^8.18.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
